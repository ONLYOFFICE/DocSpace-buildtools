<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.onlyoffice.aiworker</string>

    <key>WorkingDirectory</key>
    <string>${DOCSPACE_ROOT}</string>
   
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/share/dotnet/dotnet</string>
        <string>server/products/ASC.AI/Worker/bin/Debug/ASC.AI.Worker.dll</string>
        <string>urls=http://0.0.0.0:5154</string>
        <string>$STORAGE_ROOT=${DOCSPACE_ROOT}/Data</string>
        <string>log:dir=${DOCSPACE_ROOT}/Logs</string>
        <string>log:name=ai.worker</string>
        <string>pathToConf=${DOCSPACE_ROOT}/buildtools/config</string>
        <string>core:products:folder=${DOCSPACE_ROOT}/server/products</string>
        <string>core:eventBus:subscriptionClientName=asc_event_bus_ai_service_queue</string>
    </array>

    <key>RunAtLoad</key>
    <false/>

    <!--<key>StandardErrorPath</key>
    <string>${DOCSPACE_ROOT}/Logs/com.onlyoffice.aiworker.err</string>-->

    <!--<key>StandardOutPath</key>
    <string>${DOCSPACE_ROOT}/Logs/com.onlyoffice.aiworker.log</string>-->

    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
