<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.onlyoffice.webapi</string>

    <key>WorkingDirectory</key>
    <string>${DOCSPACE_ROOT}</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/share/dotnet/dotnet</string>
        <string>server/web/ASC.Web.Api/bin/Debug/ASC.Web.Api.dll</string>
        <string>urls=http://0.0.0.0:5000</string>
        <string>$STORAGE_ROOT=${DOCSPACE_ROOT}/Data</string>
        <string>log:dir=${DOCSPACE_ROOT}/Logs</string>
        <string>log:name=web.api</string>
        <string>pathToConf=${DOCSPACE_ROOT}/buildtools/config</string>
        <string>core:products:folder=${DOCSPACE_ROOT}/server/products</string>
    </array>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <true/>

    <!--<key>StandardOutPath</key>
    <string>${DOCSPACE_ROOT}/Logs/webapi.stdout.log</string>-->

    <!--<key>StandardErrorPath</key>
    <string>${DOCSPACE_ROOT}/Logs/webapi.stderr.log</string>-->
</dict>
</plist>
