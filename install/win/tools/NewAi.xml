<service>
	<id>DocSpace.NewAi</id>
	<name>ONLYOFFICE DocSpace NewAi</name>
	<description>ONLYOFFICE DocSpace NewAi</description>
	<priority>RealTime</priority>
	<startmode>Automatic</startmode>
	<autoRefresh>false</autoRefresh>
	<onfailure action="restart" delay="10 sec"/>
	<logpath>{APPDIR}Logs</logpath>
	<env name="API_HOST" value="{API_HOST}"/>
	<env name="AI_SERVICE_URL" value="{AI_SERVICE_URL}"/>
	<executable>node</executable>
	<arguments>&quot;{APPDIR}services\ASC.NewAi\service\server.js&quot;</arguments>
	<log mode="roll-by-size">
  		<sizeThreshold>10240</sizeThreshold>
  		<keepFiles>8</keepFiles>
	</log>
</service>